{
  "name": "opncreator",
  "displayName": "OpnCreator",
  "description": "Quickly add operation classes to the DCAD codebase",
  "version": "1.1.0",
  "publisher": "giahuy",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./extension.js",
  "scripts": {
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.74.0",
    "@vscode/test-electron": "^2.4.1",
    "glob": "^10.4.5",
    "mocha": "^10.7.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "opncreator.create",
        "title": "OpnCreator: Create Operation"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "opncreator.create",
          "group": "navigation"
        }
      ]
    }
    ,
    "keybindings": [
      {
        "command": "opncreator.create",
        "key": "alt+shift+o",
        "mac": "cmd+shift+o"
      }
    ]
  }
}
